# Use object initializers
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/style-rules/ide0017
dotnet_diagnostic.IDE0010.severity = silent # only affects code generators
    # Justification: sometimes code is less readable when using an object initializer.
    # Especially when some properties (e.g. lists) need to be updated outside of the initializer.

# Use collection initializers or expressions
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/style-rules/ide0028
dotnet_diagnostic.IDE0028.severity = silent # only affects code generators
    # Justification: "myList.ToImmutableArray()" is more readable than "[.. myList]" and
    # it only gets worse when you consider: "[.. myList.Where(x => x.ShouldInclude).Select(x => x.Child)]".
    # Having said that, initalizing lists with "[]" or "[1, 2, 3]" is absolutely recommended.
    # Shame that Microsoft didn't split those two very different scenarios into different warnings.

# Null check can be simplified
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/style-rules/ide0029-ide0030-ide0270
dotnet_diagnostic.IDE0029.severity = warning
dotnet_diagnostic.IDE0030.severity = warning
dotnet_diagnostic.IDE0270.severity = silent # only affects code generators
    # Justification: sometimes code becomes less readable when using the null coalesce for
    # throwing exceptions. Developers should be allowed to make the call case-by-case.

# Use null propagation
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/style-rules/ide0031
dotnet_diagnostic.IDE0031.severity = warning

# Use auto-implemented property
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/style-rules/ide0032
dotnet_diagnostic.IDE0032.severity = warning

# Use explicitly provided tuple name
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/style-rules/ide0033
dotnet_diagnostic.IDE0033.severity = warning

# Remove unreachable code
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/style-rules/ide0035
dotnet_diagnostic.IDE0035.severity = warning

# Use inferred member names
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/style-rules/ide0037
dotnet_diagnostic.IDE0037.severity = warning
dotnet_style_prefer_inferred_tuple_names = false
dotnet_style_prefer_inferred_anonymous_type_member_names = false
    # Justification: remaining consistent between assignments that can and cannot be inferred.
    # E.g. "new { x, y = 123 }" is less readable than "new { x = x, y = 123}"
    # Second justification: inferred names usually violate naming conventions.
    # E.g. "new { x, Y = 123 }" (public properties should be pascal case but "x" is lowercase).

# Use 'is null' check
