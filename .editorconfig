dotnet_diagnostic.IDE0090.severity = silent # only affects code generators
    # Justification: when combined with "prefer var" rules, this can lead to clashing
    # code style warnings. Also there are scenarios where "new()" is less readable
    # than including the type name. Having said that, developers are still encouraged
    # to omit type names where it can improve code readability

