# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/style-rules/ide0305
dotnet_diagnostic.IDE0305.severity = none
    # Justification: "myList.ToImmutableArray()" is more readable than "[.. myList]" and
